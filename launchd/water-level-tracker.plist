<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.{userName}.water-level-tracker</string>

  <key>ProgramArguments</key>
  <array>
    <string>/opt/homebrew/bin/pnpm</string>
    <string>start</string>
    <string>--commitAndPush</string>
  </array>

  <key>WorkingDirectory</key>
  <string>/Users/{userName}/water-level-tracker</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
  </dict>

  <key>StartCalendarInterval</key>
  <array>
    <dict>
      <key>Hour</key>
      <integer>10</integer>
      <key>Minute</key>
      <integer>0</integer>
    </dict>
  </array>

  <key>PreventSystemSleep</key>
  <true/>

  <key>StandardOutPath</key>
  <string>/Users/{userName}/Library/Logs/water-level-tracker.log</string>

  <key>StandardErrorPath</key>
  <string>/Users/{userName}/Library/Logs/water-level-tracker.error.log</string>
</dict>
</plist>
